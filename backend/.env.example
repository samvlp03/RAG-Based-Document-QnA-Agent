# ── Ollama ─────────────────────────────────────────────────────────────────
LLM_MODEL=llama3.1:8b
LLM_KEEP_ALIVE=10m
EMBEDDING_MODEL=nomic-embed-text

# ── ChromaDB ────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=documents

# ── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=400
CHUNK_OVERLAP=80

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVER_K=4
RETRIEVER_FETCH_K=15
RETRIEVER_LAMBDA_MULT=0.75
RETRIEVER_STRATEGY=mmr

# ── Supabase Auth (leave blank for local dev without auth) ───────────────────
